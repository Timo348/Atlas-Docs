# Public URL of the installation
APP_URL=http://localhost:30002
WEB_PORT=30002
COLLAB_PORT=30003
COLLAB_PUBLIC_URL=ws://localhost:30003
ATLAS_VERSION=1.0.1

# local | oidc | both
AUTH_MODE=local
AUTH_SECRET=replace-with-at-least-32-random-characters

# Initial administrator (created only when it does not exist)
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now

# Authentik / generic OpenID Connect (required for oidc or both)
OIDC_ISSUER=https://auth.example.com/application/o/atlas-docs/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Internal infrastructure
POSTGRES_DB=atlas
POSTGRES_USER=atlas
POSTGRES_PASSWORD=replace-with-a-long-database-password
DATABASE_URL=postgresql://atlas:replace-with-a-long-database-password@postgres:5432/atlas
REDIS_URL=redis://redis:6379
