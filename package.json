{
  "name": "atlas-docs",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=@atlas/web && npm run build --workspace=@atlas/collab",
    "lint": "npm run lint --workspace=@atlas/web && npm run lint --workspace=@atlas/collab",
    "test": "npm run test --workspace=@atlas/web && npm run test --workspace=@atlas/collab",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "prisma": "6.19.3",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  },
  "overrides": {
    "cookie": "0.7.2",
    "effect": "3.21.4",
    "lodash-es": "4.18.1",
    "postcss": "8.5.16",
    "uuid": "11.1.1",
    "@excalidraw/excalidraw": {
      "nanoid": "3.3.11"
    },
    "@excalidraw/mermaid-to-excalidraw": {
      "nanoid": "5.1.16"
    }
  }
}
